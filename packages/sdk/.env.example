# Database Configuration
DATABASE_URL=postgresql://user:password@localhost:5432/veraz_db
# For MySQL: mysql://user:password@localhost:3306/veraz_db
# For MongoDB: mongodb://localhost:27017/veraz_db

# Supabase Configuration (Recommended)
# Get these from: Supabase Dashboard → Project Settings → Database
SUPABASE_CONNECTION_STRING=postgresql://postgres:[YOUR-PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres
# Optional: For REST API connection
# SUPABASE_URL=https://[PROJECT-REF].supabase.co
# SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Stellar Configuration
STELLAR_SECRET_KEY=SXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
# Verifier Contract (Solvency Circuit - Testnet)
CONTRACT_ID=CBURMJENDNJRGVVFPF4MUZQKWGDVDWAHKVWLVRGBSEZMVNKZRPHEOVXJ

# Circuit Configuration
CIRCUIT_PATH=./circuits/solvency.json

